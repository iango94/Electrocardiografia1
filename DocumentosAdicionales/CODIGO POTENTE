# NUEVO MÓDULO ALGORÍTMICO: EVALUACIÓN ISQUÉMICA AUTOMÁTICA
# ========================================================
def analizar_criterios_isquemia(signal_clean, info_peaks):
    """
    Analiza la señal limpia buscando elevaciones/depresiones del segmento ST,
    mide pendientes y evalúa el árbol lógico de decisión médica.
    """
    alertas = []
    probabilidad = "Baja / Normal"
    
    try:
        # Delinear ondas completas usando transformada de ondícula discreta (DWT)
        _, waves = nk.ecg_delineate(signal_clean, info_peaks["ECG_R_Peaks"], sampling_rate=FS, method="dwt")
        
        r_offsets = waves['ECG_R_Offsets'] # El final del QRS es técnicamente el Punto J
        t_peaks = waves['ECG_T_Peaks']
        t_offsets = waves['ECG_T_Offsets']
        t_onsets = waves['ECG_T_Onsets']
        p_peaks = waves['ECG_P_Peaks']
        
        st_elevations = []
        st_slopes = []
        t_wave_amplitudes = []
        
        # Analizar ciclo por ciclo cardíaco válido encontrado
        for i in range(len(info_peaks["ECG_R_Peaks"]) - 1):
            j_point_idx = r_offsets[i]
            t_peak_idx = t_peaks[i]
            t_offset_idx = t_offsets[i]
            t_onset_idx = t_onsets[i]
            
            # Validar que los índices no contengan NaN
            if np.isnan(j_point_idx) or np.isnan(t_peak_idx):
                continue
                
            j_point_idx = int(j_point_idx)
            t_peak_idx = int(t_peak_idx)
            
            # --- ESTABLECIMIENTO DE LÍNEA BASE (Usando el segmento isoeléctrico PR previo) ---
            # Si no hay onda P mapeada con precisión, se toma un offset relativo antes de la R
            base_idx = int(info_peaks["ECG_R_Peaks"][i] - (0.05 * FS)) 
            if i < len(p_peaks) and not np.isnan(p_peaks[i]):
                base_idx = int(p_peaks[i])
            v_linea_base = signal_clean[base_idx]
            
            # --- MEDICIÓN DEL SEGMENTO ST ---
            # El segmento ST se evalúa típicamente a J + 60ms o J + 80ms (21 a 28 muestras a 360Hz)
            st_sample_idx = min(j_point_idx + int(0.06 * FS), len(signal_clean) - 1)
            
            # Amplitud ST relativa a la línea base (en mV)
            st_amplitude_mv = signal_clean[st_sample_idx] - v_linea_base
            st_elevations.append(st_amplitude_mv)
            
            # Pendiente matemática del segmento ST (Derivada discreta)
            slope = (signal_clean[st_sample_idx] - signal_clean[j_point_idx]) / (st_sample_idx - j_point_idx)
            st_slopes.append(slope)
            
            # --- MEDICIÓN ONDA T ---
            t_amp_mv = signal_clean[t_peak_idx] - v_linea_base
            t_wave_amplitudes.append(t_amp_mv)
            
        if len(st_elevations) == 0:
            return "Datos insuficientes para evaluación", "Baja", []

        # Promedios de la ventana analizada
        avg_st_elevation = np.nanmean(st_elevations)
        avg_st_slope = np.nanmean(st_slopes)
        avg_t_amplitude = np.nanmean(t_wave_amplitudes)
        
        # Conversión clínica: 0.1 mV = 1 mm en papel milimetrado convencional ECG
        st_mm = avg_st_elevation * 10.0 
        t_mm = avg_t_amplitude * 10.0

        # ========================================================
        # EJECUCIÓN ARBOL LÓGICO DE DECISIÓN MÉDICA (AHA / ESC)
        # ========================================================
        
        # 1. EVALUACIÓN: PROBABILIDAD EXTREMA
        # Ondas T hiperagudas (Amplitudes muy altas simétricas > 10mm precordiales o > 5mm periféricas)
        if t_mm > 8.0:
            alertas.append("Ondas T hiperagudas detectadas (Posible Isquemia Hiperaguda Temprana)")
            probabilidad = "EXTREMA"
            
        # 2. EVALUACIÓN: PROBABILIDAD ALTA
        # Elevación franca generalizada del ST (> 1mm o 0.1mV) o depresión severa
        if st_mm >= 1.0:
            alertas.append(f"Elevación franca del segmento ST ({st_mm:.2f} mm). Sugestivo de IAMCEST.")
            probabilidad = "ALTA" if probabilidad != "EXTREMA" else "EXTREMA"
        elif st_mm <= -0.5:
            alertas.append(f"Depresión del segmento ST ({abs(st_mm):.2f} mm). Sugestivo de Isquemia Subendocárdica / IAMSEST.")
            probabilidad = "ALTA" if probabilidad != "EXTREMA" else "EXTREMA"
            
        if t_mm < -2.0:
            alertas.append("Inversión marcada y profunda de la onda T (Isquemia miocárdica evolucionada).")
            if probabilidad == "Baja / Normal": probabilidad = "ALTA"

        # 3. EVALUACIÓN: PROBABILIDAD MEDIA
        if (0.5 > st_mm > 0.2) and avg_st_slope < 0:
            alertas.append("Leve alteración del ST con pendiente negativa.")
            if probabilidad == "Baja / Normal": probabilidad = "MEDIA"

    except Exception as e:
        alertas.append(f"Error en procesado matemático de sub-ondas: {str(e)}")
        
    return probabilidad, alertas, r_offsets

