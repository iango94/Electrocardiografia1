def normalize(signal):
    signal = np.array(signal)
    # Conversión a mV asumiendo rango dinámico del ADC y acondicionamiento analógico
    signal = ((signal / DIVISOR_TENSION) * 3.3) - 1.65 
    return signal

def filtrar_ECG(senal):
    return nk.ecg_clean(senal, sampling_rate=FS, method=NK_METHOD)

